{
  "project": "douyin-qa-template",
  "format": "douyin-vertical",
  "fps": 30,
  "resolution": "1080x1920",
  "assets": [
    {
      "id": "clip1",
      "type": "video",
      "path": "./assets/input.mp4"
    }
  ],
  "timeline": [
    {"type": "clip", "asset": "clip1", "start": 0, "end": 3},
    {"type": "subtitle", "start": 0, "end": 3, "text": "问题抛出，先抓注意力"},
    {"type": "clip", "asset": "clip1", "start": 3, "end": 6},
    {"type": "subtitle", "start": 3, "end": 6, "text": "第二段给结论或动作建议"}
  ],
  "subtitles": {
    "fontName": "PingFang SC",
    "primaryColor": "#FFFFFF",
    "outlineColor": "#000000",
    "outline": 3,
    "marginV": 160,
    "maxCharsPerLine": 18
  },
  "music": {
    "style": "qa-short"
  },
  "cover": {
    "enabled": true,
    "title": "问题抛出，先抓注意力"
  },
  "publish": {
    "title": "问题抛出，先抓注意力",
    "hashtags": ["#抖音模板", "#问答短视频", "#知识分享"],
    "description": "这是通过模板初始化后的二次编辑示例，可继续替换字幕、水印和音乐。"
  },
  "output": {
    "path": "./output/video/douyin_template_render.mp4",
    "platform": "douyin"
  }
}
