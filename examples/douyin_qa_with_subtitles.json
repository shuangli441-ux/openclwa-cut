{
  "project": "douyin-qa-subtitles",
  "assets": [
    {
      "id": "main",
      "type": "video",
      "path": "./assets/input.mp4"
    }
  ],
  "subtitles": {
    "fontName": "PingFang SC",
    "fontSize": 60,
    "primaryColor": "#FFFFFF",
    "outlineColor": "#000000",
    "outline": 3,
    "marginV": 180,
    "maxCharsPerLine": 18
  },
  "music": {
    "path": "./audio/bgm.m4a",
    "style": "qa-short",
    "volume": 0.14,
    "fadeOutSeconds": 1.2,
    "duckingThreshold": 0.035,
    "duckingRatio": 10,
    "duckingAttackMs": 20,
    "duckingReleaseMs": 350,
    "voiceHighpassHz": 120,
    "voiceLowpassHz": 9000,
    "voiceBoost": 1.05
  },
  "aiEdit": {
    "enabled": true,
    "mode": "smart",
    "templateKind": "douyin-qa",
    "maxDurationSeconds": 18,
    "hookSeconds": 3,
    "ctaSeconds": 4,
    "scriptLines": [
      "客户突然多了预收款？",
      "先别慌，找到原单据直接撤销就行",
      "最后再核对流水，避免重复记账"
    ]
  },
  "cover": {
    "enabled": true,
    "title": "预收款撤销怎么做",
    "titleFontSize": 92,
    "titleColor": "#FFFFFF"
  },
  "publish": {
    "title": "预收款撤销怎么做",
    "hashtags": ["#财税答疑", "#知识分享", "#抖音短视频"],
    "description": "适合知识答疑类短视频：前 3 秒先抛问题，中段给结论，结尾补操作提醒。"
  },
  "output": {
    "path": "./output/video/douyin_qa_with_subtitles.mp4",
    "platform": "douyin"
  }
}
